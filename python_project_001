import random

words = ["python", "program", "developer", "hangman", "challenge"]

secret_word = random.choice(words)
letters = list(secret_word)

guessed_letters = []
tries = 6

print("ハングマンへようこそ！")

p = "_" * len(secret_word)

while tries > 0:
    print("\n現在の単語:", p)
    print(f"残りの試行回数: {tries}")
    print("これまでの推測:", " ".join(guessed_letters))

    guess = input("一文字を予想してください: ").lower()

    if len(guess) != 1:
        print("1文字だけ入力してください。")
        continue

    if not guess.isalpha():
        print("アルファベットを入力してください。")
        continue

    if guess in guessed_letters:
        print("すでに予想した文字です。")
        continue

    guessed_letters.append(guess)

    if guess in letters:
        print("正解です！")
    else:
        print("不正解です。")
        tries -= 1

    display_word = ""

    for letter in letters:
        if letter in guessed_letters:
            display_word += letter
        else:
            display_word += "_"

    p = display_word

    if p == secret_word:
        print("\nおめでとうございます！")
        print(f"正解は「{secret_word}」でした。")
        break

if tries == 0:
    print(f"\n残念！正解は「{secret_word}」でした。")
